// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © graphicsperry01
//
// Mirrors strategy.py pure-SMC path (USE_XGBOOST=false defaults):
//   * soft institutional score (bias + edges; vol/disp are bonuses)
//   * recent liquidity sweeps (not same-bar only)
//   * open FVG lookback + CRT (1H sweep-reclaim)
//   * structure SL: wider of entry+bias TF swing + buffer AND min ATR floor
//   * prediction limit zones: deepest valid of OB mid / FVG mid / ATR pullback
//   * soft confidence bar for Limit mode; stricter for Market mode
// XGBoost / expected-R cannot run in Pine — confidence is pure SMC + bonuses.

//@version=6
indicator("SMC Whale AI", overlay = true, max_labels_count = 500, max_boxes_count = 500, max_lines_count = 500)

//====================================================
// PART 1 -- INPUTS  (defaults match config.py)
//====================================================

// Trading mode.
//   Auto   : entry = CURRENT chart TF, trend = next HTF up.
//   Scalp  : 15m trend / 5m entry     (bot default SCAN stack)
//   Day    : 1H  trend / 15m entry
//   Swing  : 4H  trend / 30m entry
//   Custom : use the two Custom TF fields (ignored otherwise).
tradeMode = input.string("Auto", "Trading Mode", options = ["Auto", "Scalp", "Day", "Swing", "Custom"], group = "Timeframes",
     tooltip = "Auto = entry matches chart, trend = next HTF.\nScalp = 15m/5m · Day = 1H/15m · Swing = 4H/30m.\nCustom = fields below only.")

customTrendTF = input.timeframe("15", "Custom Trend TF (Custom mode only)", group = "Timeframes")
customEntryTF = input.timeframe("5", "Custom Entry TF (Custom mode only)", group = "Timeframes")

chartSecs = timeframe.in_seconds()
autoEntryTF = timeframe.period
autoTrendTF = chartSecs <= 60 ? "5" : chartSecs <= 300 ? "15" : chartSecs <= 900 ? "60" : chartSecs <= 3600 ? "240" : chartSecs <= 14400 ? "D" : "W"

trendTF = tradeMode == "Auto" ? autoTrendTF : tradeMode == "Scalp" ? "15" : tradeMode == "Day" ? "60" : tradeMode == "Swing" ? "240" : customTrendTF
entryTF = tradeMode == "Auto" ? autoEntryTF : tradeMode == "Scalp" ? "5"  : tradeMode == "Day" ? "15" : tradeMode == "Swing" ? "30"  : customEntryTF

showDashboard = input.bool(true, "Dashboard", group = "Display")
showSignals   = input.bool(true, "Signals", group = "Display")
showBOS       = input.bool(true, "Break of Structure", group = "Display")
showFVG       = input.bool(true, "Fair Value Gaps", group = "Display")
showLiquidity = input.bool(true, "Liquidity Sweeps", group = "Display")
showLevels    = input.bool(true, "Entry / SL / TP / Invalidation", group = "Display")
showOB        = input.bool(true, "Order Blocks", group = "Display")
showPD        = input.bool(true, "Premium / Discount Zones", group = "Display")
showEQ        = input.bool(true, "Equal Highs / Lows", group = "Display")
showKillzones = input.bool(true, "Killzones", group = "Display")
showHeatmap   = input.bool(true, "Liquidity Heatmap", group = "Display")
showAIBar     = input.bool(true, "Confidence Bar", group = "Display")
showCRT       = input.bool(true, "CRT Markers", group = "Display")

// ---- Structure (strategy.py BOS defaults) ----
structureLookback = input.int(10, "BOS Structure Lookback", group = "Structure")
confirmCandles    = input.int(2, "BOS Confirm Candles", group = "Structure")
internalLookback  = input.int(5, "Internal BOS Lookback", group = "Structure")
internalConfirm   = input.int(1, "Internal BOS Confirm Candles", group = "Structure")

// Pure-SMC displacement (config / strategy: 0.50 when USE_XGBOOST=false)
displacementATR = input.float(0.50, "Displacement ATR Multiplier", group = "Structure", step = 0.05)

// ---- Entry mode + soft gates (config.py) ----
entryMode = input.string("Limit (prediction)", "Entry Mode",
     options = ["Limit (prediction)", "Market (close)"], group = "Entry / Limits",
     tooltip = "Limit = rest at OB/FVG/ATR zone (bot ENTRY_MODE=limit).\nMarket = chase signal close.")
retraceATR = input.float(0.45, "Retrace Depth (xATR, no-FVG/OB fallback)", group = "Entry / Limits", step = 0.05)
confLimit  = input.int(28, "Confidence Required (Limit mode)", group = "Entry / Limits",
     tooltip = "CONFIDENCE_REQUIRED_LIMIT — softer so predictions can rest.")
confMarket = input.int(40, "Confidence Required (Market mode)", group = "Entry / Limits",
     tooltip = "CONFIDENCE_REQUIRED_SMC")
minSetupScore = input.int(20, "Min Soft Setup Score (Limit mode)", group = "Entry / Limits",
     tooltip = "LIMIT_MIN_SETUP_SCORE — HTF bias + at least one edge.")

// ---- Anti stop-hunt (config.py) ----
// Swing = wider of entry TF + trend TF so SL is not under 15m equal-low bait.
minSlAtr = input.float(1.15, "Min SL Distance (xATR)", group = "Stop Placement", step = 0.05)
structSlBufferAtr = input.float(0.25, "Structure SL Buffer (xATR)", group = "Stop Placement", step = 0.05)
structSwingLookback = input.int(20, "Structure Swing Lookback (bars per TF)", group = "Stop Placement")

// ---- Display-only extras (not part of bot signal gate) ----
pdLookback     = input.int(50, "Premium/Discount Range Lookback", group = "Premium/Discount")
pivotBars      = input.int(3, "Pivot Bars (Equal Highs/Lows)", group = "Liquidity")
eqTolerancePct = input.float(0.05, "Equal High/Low Tolerance %", group = "Liquidity") / 100
obExtendBars   = input.int(20, "Order Block Box Length (bars)", group = "Order Blocks")
maxOBBoxes     = input.int(8, "Max Order Blocks Shown", group = "Order Blocks")

//====================================================
// COLORS
//====================================================

bullColor    = color.new(color.lime, 0)
bearColor    = color.new(color.red, 0)
neutralColor = color.new(color.gray, 60)
limitColor   = color.new(color.blue, 0)
invColor     = color.new(color.orange, 0)

f_tfLabel(tf) =>
    str.contains(tf, "D") or str.contains(tf, "W") or str.contains(tf, "M") or str.contains(tf, "S") ? tf : tf == "60" ? "1H" : tf == "120" ? "2H" : tf == "180" ? "3H" : tf == "240" ? "4H" : tf + "m"

//====================================================
// PART 2 -- HTF BOS  (bullish_bos / bearish_bos)
//====================================================
// structure window excludes last `confirm` candles; ALL confirm closes
// must be beyond the swing (not wick-only).

f_htf_bos(lookback, confirm) =>
    swingHigh = ta.highest(high[confirm], lookback)
    swingLow  = ta.lowest(low[confirm], lookback)
    bullBOS = true
    bearBOS = true
    for i = 0 to confirm - 1
        bullBOS := bullBOS and (close[i] > swingHigh)
        bearBOS := bearBOS and (close[i] < swingLow)
    [bullBOS, bearBOS]

[trendBull, trendBear] = request.security(
     syminfo.tickerid, trendTF, f_htf_bos(structureLookback, confirmCandles), barmerge.gaps_off, barmerge.lookahead_off)

[internalBullRaw, internalBearRaw] = request.security(
     syminfo.tickerid, entryTF, f_htf_bos(internalLookback, internalConfirm), barmerge.gaps_off, barmerge.lookahead_off)

//====================================================
// PART 2 -- ENTRY TF CORE
// volume spike, displacement, same-bar + recent sweep, FVG (+ open gaps),
// CRT, order-block mid, structure swing, regime
//====================================================

f_entry_core(dispMult, sweepLookback, sweepSwingWin, obLookback, structLb) =>
    // ATR = (high-low).rolling(14).mean() — NOT Wilder ta.atr (matches Python)
    atrVal = ta.sma(high - low, 14)
    volMA = ta.sma(volume, 20)
    atrAvgLocal = ta.sma(atrVal, 30)

    // adaptive volume multiplier (pure SMC / non-XGBoost)
    volMult = atrVal > atrAvgLocal * 1.3 ? 1.15 : 1.30
    volSpike = volume > volMA * volMult
    body = math.abs(close - open)
    displacementFlag = body > atrVal * dispMult

    // Same-bar sweep (strategy: iloc[-10:-1] → 9 bars before current)
    swingLowEntry  = ta.lowest(low[1], 9)
    swingHighEntry = ta.highest(high[1], 9)
    bullSweepNow = low <= swingLowEntry * 1.0002 and close > open
    bearSweepNow = high >= swingHighEntry * 0.9998 and close < open

    // recent_liquidity_sweep(lookback=8, swing_window=12)
    bool bullSweepRecent = false
    bool bearSweepRecent = false
    for i = 1 to sweepLookback
        winLow  = ta.lowest(low[i + 1], sweepSwingWin)
        winHigh = ta.highest(high[i + 1], sweepSwingWin)
        if low[i] < winLow and close[i] > open[i]
            bullSweepRecent := true
        if high[i] > winHigh and close[i] < open[i]
            bearSweepRecent := true
    bullSweep = bullSweepNow or bullSweepRecent
    bearSweep = bearSweepNow or bearSweepRecent

    // Current-bar FVG
    bullFvgNow = low > high[2]
    bearFvgNow = high < low[2]
    // Still-open prior FVG (k in 2..4) — strategy.py open-gap scan
    bool bullFvgOpen = false
    bool bearFvgOpen = false
    for k = 2 to 4
        // gap between bar[k] low and bar[k+2] high (bullish imbalance)
        if low[k] > high[k + 2] and close > high[k + 2]
            bullFvgOpen := true
        if high[k] < low[k + 2] and close < low[k + 2]
            bearFvgOpen := true
    bullFvg = bullFvgNow or bullFvgOpen
    bearFvg = bearFvgNow or bearFvgOpen

    // FVG mid for zone choice (current gap geometry, matches high[-3]/low[-1])
    bullFvgMid = (high[2] + low) / 2.0
    bearFvgMid = (low[2] + high) / 2.0

    // find_order_block: walk last obLookback bars (exclude signal bar)
    // LONG → last bearish candle before bullish impulse; mid = (open+low)/2
    // SHORT → last bullish candle before bearish impulse; mid = (open+high)/2
    float obLongMid = na
    float obShortMid = na
    bool foundLongOB = false
    bool foundShortOB = false
    for i = 1 to obLookback
        // impulse at bar[i], opposing candle at bar[i+1] (older)
        bodyI = math.abs(close[i] - open[i])
        atrI = (high[i] - low[i])  // local bar range proxy; impulse vs 0.55*ATR
        // Prefer rolling ATR if available on this offset
        atrRoll = ta.sma(high - low, 14)
        atrUse = na(atrRoll[i]) or atrRoll[i] <= 0 ? math.max(bodyI, atrI) : atrRoll[i]
        if not foundLongOB and close[i] > open[i] and bodyI > atrUse * 0.55 and close[i + 1] < open[i + 1]
            obLongMid := (open[i + 1] + low[i + 1]) / 2.0
            foundLongOB := true
        if not foundShortOB and close[i] < open[i] and bodyI > atrUse * 0.55 and close[i + 1] > open[i + 1]
            obShortMid := (open[i + 1] + high[i + 1]) / 2.0
            foundShortOB := true

    // Structure swing for SL (exclude signal bar): iloc[-(lookback+1):-1]
    structSwingLow  = ta.lowest(low[1], structLb)
    structSwingHigh = ta.highest(high[1], structLb)

    // detect_market_regime: volatile if ATR>avg*1.4 else trending if 30-bar move>4%
    priceChange = na(close[30]) ? 0.0 : math.abs(close - close[30]) / close[30]
    regimeCode = atrVal > atrAvgLocal * 1.4 ? 2 : priceChange > 0.04 ? 1 : 0

    // OB anchor for drawing boxes (last opposing candle before current impulse)
    obBullCandle = close > open and close[1] < open[1]
    obBearCandle = close < open and close[1] > open[1]
    obHigh = high[1]
    obLow  = low[1]

    [volSpike, displacementFlag, bullSweep, bearSweep, bullSweepNow, bearSweepNow,
     bullFvg, bearFvg, bullFvgMid, bearFvgMid,
     atrVal, atrAvgLocal, regimeCode,
     obLongMid, obShortMid, foundLongOB, foundShortOB,
     structSwingLow, structSwingHigh,
     obBullCandle, obBearCandle, obHigh, obLow]

[volSpike, displacementFlag, bullSweep, bearSweep, bullSweepNow, bearSweepNow,
 bullFvg, bearFvg, bullFvgMid, bearFvgMid,
 entryATR, entryATRAvg, regimeCode,
 obLongMid, obShortMid, foundLongOB, foundShortOB,
 structSwingLowEntry, structSwingHighEntry,
 obBullCandle, obBearCandle, obHigh, obLow] =
     request.security(syminfo.tickerid, entryTF,
          f_entry_core(displacementATR, 8, 12, 15, structSwingLookback),
          barmerge.gaps_off, barmerge.lookahead_off)

// Bias-TF structure swing (same lookback bars on trend TF). Wider of entry +
// bias so SL clears the stop-hunt bait that shows on the 15m chart.
f_struct_swing(structLb) =>
    [ta.lowest(low[1], structLb), ta.highest(high[1], structLb)]

[structSwingLowBias, structSwingHighBias] = request.security(
     syminfo.tickerid, trendTF, f_struct_swing(structSwingLookback),
     barmerge.gaps_off, barmerge.lookahead_off)

structSwingLow  = math.min(structSwingLowEntry, structSwingLowBias)
structSwingHigh = math.max(structSwingHighEntry, structSwingHighBias)

// CRT on 1H: cur hour sweeps prior completed hour's extreme + reclaim
// (crt_flags in strategy.py)
prevH1Low  = request.security(syminfo.tickerid, "60", low[1],  barmerge.gaps_off, barmerge.lookahead_off)
prevH1High = request.security(syminfo.tickerid, "60", high[1], barmerge.gaps_off, barmerge.lookahead_off)
curH1Low   = request.security(syminfo.tickerid, "60", low,     barmerge.gaps_off, barmerge.lookahead_off)
curH1High  = request.security(syminfo.tickerid, "60", high,    barmerge.gaps_off, barmerge.lookahead_off)
// close from entry TF (latest close)
entryClose = request.security(syminfo.tickerid, entryTF, close, barmerge.gaps_off, barmerge.lookahead_off)
bullCrt = curH1Low < prevH1Low and entryClose > prevH1Low
bearCrt = curH1High > prevH1High and entryClose < prevH1High

//====================================================
// PART 2 -- SOFT SMC SCORE  (strategy.py get_signal)
//====================================================
// trend 20 | sweep 20 | FVG 15 | CRT 15 | vol 15 | disp 15 | OB 10
// max theoretical = 110

smcScore = 0
smcScore := smcScore + ((trendBull or trendBear) ? 20 : 0)
smcScore := smcScore + ((bullSweep or bearSweep) ? 20 : 0)
smcScore := smcScore + ((bullFvg or bearFvg) ? 15 : 0)
smcScore := smcScore + ((bullCrt or bearCrt) ? 15 : 0)
smcScore := smcScore + (volSpike ? 15 : 0)
smcScore := smcScore + (displacementFlag ? 15 : 0)
smcScore := smcScore + (((trendBull and foundLongOB) or (trendBear and foundShortOB)) ? 10 : 0)

useLimit = entryMode == "Limit (prediction)"

// RR from soft score (pure-SMC branch in strategy.py)
rrValue = smcScore >= 70 ? 2.0 : smcScore >= 45 ? 1.75 : 1.5

//====================================================
// PART 2 -- STRUCTURE STOP + PREDICTION LIMIT ZONE
//====================================================

f_structure_stop_long(entryPx, atr, swingLow) =>
    buffer = atr * structSlBufferAtr
    floorDist = atr * minSlAtr
    structureSl = swingLow - buffer
    atrFloor = entryPx - floorDist
    sl = math.min(structureSl, atrFloor)
    sl := math.min(sl, entryPx - atr * 0.10)
    sl

f_structure_stop_short(entryPx, atr, swingHigh) =>
    buffer = atr * structSlBufferAtr
    floorDist = atr * minSlAtr
    structureSl = swingHigh + buffer
    atrFloor = entryPx + floorDist
    sl = math.max(structureSl, atrFloor)
    sl := math.max(sl, entryPx + atr * 0.10)
    sl

// Signal-close economics first
signalClose = entryClose
atrSafe = entryATR > 0 ? entryATR : 1.0

longSL0  = f_structure_stop_long(signalClose, atrSafe, structSwingLow)
shortSL0 = f_structure_stop_short(signalClose, atrSafe, structSwingHigh)

// choose_limit_zone — deepest valid of OB / FVG / ATR pullback
// LONG: pick lowest valid candidate; SHORT: highest valid
f_choose_limit_long(entryPx, sl, atr, hasFvg, fvgMid, hasOb, obMid, retrace) =>
    atrPull = entryPx - atr * retrace
    minLimit = sl + 0.30 * (entryPx - sl)
    float best = na
    string zone = "atr_pullback"
    // evaluate candidates (deeper = better for long)
    if hasFvg and not na(fvgMid) and fvgMid >= minLimit and fvgMid <= entryPx
        best := fvgMid
        zone := "fvg"
    if hasOb and not na(obMid) and obMid >= minLimit and obMid <= entryPx
        if na(best) or obMid < best
            best := obMid
            zone := "order_block"
    if atrPull >= minLimit and atrPull <= entryPx
        if na(best) or atrPull < best
            best := atrPull
            zone := "atr_pullback"
    if na(best)
        best := math.max(minLimit, math.min(entryPx, entryPx - atr * 0.25))
        zone := "atr_pullback"
    best := math.min(best, entryPx)
    best := math.max(best, minLimit)
    [best, zone]

f_choose_limit_short(entryPx, sl, atr, hasFvg, fvgMid, hasOb, obMid, retrace) =>
    atrPull = entryPx + atr * retrace
    maxLimit = sl - 0.30 * (sl - entryPx)
    float best = na
    string zone = "atr_pullback"
    if hasFvg and not na(fvgMid) and fvgMid <= maxLimit and fvgMid >= entryPx
        best := fvgMid
        zone := "fvg"
    if hasOb and not na(obMid) and obMid <= maxLimit and obMid >= entryPx
        if na(best) or obMid > best
            best := obMid
            zone := "order_block"
    if atrPull <= maxLimit and atrPull >= entryPx
        if na(best) or atrPull > best
            best := atrPull
            zone := "atr_pullback"
    if na(best)
        best := math.min(maxLimit, math.max(entryPx, entryPx + atr * 0.25))
        zone := "atr_pullback"
    best := math.max(best, entryPx)
    best := math.min(best, maxLimit)
    [best, zone]

[longLimit0, longZone0] = f_choose_limit_long(
     signalClose, longSL0, atrSafe, bullFvg, bullFvgMid, foundLongOB, obLongMid, retraceATR)
[shortLimit0, shortZone0] = f_choose_limit_short(
     signalClose, shortSL0, atrSafe, bearFvg, bearFvgMid, foundShortOB, obShortMid, retraceATR)

// Re-anchor SL/TP at the limit when in Limit mode (strategy.py)
longLimit  = longLimit0
shortLimit = shortLimit0
longZone   = longZone0
shortZone  = shortZone0

longSL_re  = f_structure_stop_long(longLimit, atrSafe, structSwingLow)
longSL_re  := math.min(longSL_re, longLimit - atrSafe * minSlAtr * 0.85)
shortSL_re = f_structure_stop_short(shortLimit, atrSafe, structSwingHigh)
shortSL_re := math.max(shortSL_re, shortLimit + atrSafe * minSlAtr * 0.85)

longSL  = useLimit ? longSL_re : longSL0
shortSL = useLimit ? shortSL_re : shortSL0

longEntry  = useLimit ? longLimit : signalClose
shortEntry = useLimit ? shortLimit : signalClose
longTP  = longEntry + (longEntry - longSL) * rrValue
shortTP = shortEntry - (shortSL - shortEntry) * rrValue

// Invalidation = structure swing (monitor cancels pending if breached)
longInv  = structSwingLow
shortInv = structSwingHigh

// Zone used for the active bias (for confidence bonus + dashboard)
activeZone = trendBull ? longZone : trendBear ? shortZone : "—"

//====================================================
// PART 2 -- CONFIDENCE + SIGNAL GATE
//====================================================

confidence = smcScore
// stacked-edge bonuses (strategy.py)
confidence := confidence + (((bullSweep and bullFvg) or (bearSweep and bearFvg)) ? 5 : 0)
confidence := confidence + ((volSpike and displacementFlag) ? 5 : 0)
confidence := confidence + (((bullCrt and bullSweep) or (bearCrt and bearSweep)) ? 4 : 0)
confidence := confidence + ((activeZone == "order_block" or activeZone == "fvg") ? 3 : 0)
confidence := math.max(0, math.min(confidence, 100))

confidenceRequired = useLimit ? confLimit : confMarket

// Soft gate: Limit needs min setup score; Market only needs conf bar
setupOkLong  = trendBull and (not useLimit or smcScore >= minSetupScore)
setupOkShort = trendBear and (not useLimit or smcScore >= minSetupScore)

longSignal  = setupOkLong  and confidence >= confidenceRequired
shortSignal = setupOkShort and confidence >= confidenceRequired

// Anti-repaint: confirmed bars only (Python drops in-progress candle)
newLong  = longSignal and not longSignal[1] and barstate.isconfirmed
newShort = shortSignal and not shortSignal[1] and barstate.isconfirmed

//====================================================
// PART 2 -- SIGNAL LABELS
//====================================================

if showSignals and newLong
    tag = useLimit ? "LIMIT " + longZone : "MARKET"
    label.new(bar_index, low,
         "🟢 BUY " + str.tostring(confidence) + "%\n" + tag + "\nsc " + str.tostring(smcScore),
         style = label.style_label_up, color = bullColor, textcolor = color.black, size = size.small)

if showSignals and newShort
    tag = useLimit ? "LIMIT " + shortZone : "MARKET"
    label.new(bar_index, high,
         "🔴 SELL " + str.tostring(confidence) + "%\n" + tag + "\nsc " + str.tostring(smcScore),
         style = label.style_label_down, color = bearColor, textcolor = color.white, size = size.small)

//====================================================
// PART 2 -- BOS / SWEEP / FVG / CRT MARKERS
//====================================================

bosUp   = trendBull and not trendBull[1]
bosDown = trendBear and not trendBear[1]

if showBOS and bosUp
    label.new(bar_index, low, "BOS ↑", style = label.style_label_up,
         color = color.new(bullColor, 70), textcolor = bullColor, size = size.tiny)

if showBOS and bosDown
    label.new(bar_index, high, "BOS ↓", style = label.style_label_down,
         color = color.new(bearColor, 70), textcolor = bearColor, size = size.tiny)

plotshape(showLiquidity and bullSweep, title = "Bull Liquidity Sweep", style = shape.triangleup,
     location = location.belowbar, color = bullColor, size = size.tiny, text = "Sweep")

plotshape(showLiquidity and bearSweep, title = "Bear Liquidity Sweep", style = shape.triangledown,
     location = location.abovebar, color = bearColor, size = size.tiny, text = "Sweep")

if showFVG and bullFvg and barstate.isconfirmed
    box.new(bar_index[2], high[2], bar_index, low, border_color = bullColor, bgcolor = color.new(bullColor, 85))

if showFVG and bearFvg and barstate.isconfirmed
    box.new(bar_index[2], low[2], bar_index, high, border_color = bearColor, bgcolor = color.new(bearColor, 85))

plotshape(showCRT and bullCrt and barstate.isconfirmed, title = "Bull CRT", style = shape.diamond,
     location = location.belowbar, color = color.aqua, size = size.tiny, text = "CRT")
plotshape(showCRT and bearCrt and barstate.isconfirmed, title = "Bear CRT", style = shape.diamond,
     location = location.abovebar, color = color.fuchsia, size = size.tiny, text = "CRT")

//====================================================
// PART 3 -- INTERNAL STRUCTURE & CHoCH
//====================================================

var string internalBias = "NEUTRAL"

newInternalBull = internalBullRaw and not internalBullRaw[1]
newInternalBear = internalBearRaw and not internalBearRaw[1]

chochBull = newInternalBull and internalBias == "BEARISH"
chochBear = newInternalBear and internalBias == "BULLISH"
internalBosBull = newInternalBull and internalBias != "BEARISH"
internalBosBear = newInternalBear and internalBias != "BULLISH"

if newInternalBull
    internalBias := "BULLISH"
if newInternalBear
    internalBias := "BEARISH"

if showBOS and chochBull
    label.new(bar_index, low, "CHoCH ↑", style = label.style_label_up,
         color = color.new(color.aqua, 60), textcolor = color.aqua, size = size.tiny)

if showBOS and chochBear
    label.new(bar_index, high, "CHoCH ↓", style = label.style_label_down,
         color = color.new(color.fuchsia, 60), textcolor = color.fuchsia, size = size.tiny)

if showBOS and internalBosBull
    label.new(bar_index, low, "ibos", style = label.style_label_up,
         color = color.new(bullColor, 85), textcolor = bullColor, size = size.tiny)

if showBOS and internalBosBear
    label.new(bar_index, high, "ibos", style = label.style_label_down,
         color = color.new(bearColor, 85), textcolor = bearColor, size = size.tiny)

//====================================================
// PART 3 -- ORDER BLOCKS (display; mid used in limit zone)
//====================================================

drawBullOB = foundLongOB and displacementFlag and close > open
drawBearOB = foundShortOB and displacementFlag and close < open
// Prefer classic opposing-candle box when present
drawBullOBClassic = obBullCandle and displacementFlag and close > open
drawBearOBClassic = obBearCandle and displacementFlag and close < open

newBullOB = (drawBullOB or drawBullOBClassic) and not (drawBullOB[1] or drawBullOBClassic[1])
newBearOB = (drawBearOB or drawBearOBClassic) and not (drawBearOB[1] or drawBearOBClassic[1])

var array<box> bullOBBoxes = array.new_box(0)
var array<box> bearOBBoxes = array.new_box(0)

if showOB and newBullOB and barstate.isconfirmed
    newBox = box.new(bar_index - 1, obHigh, bar_index + obExtendBars, obLow,
         border_color = color.new(color.blue, 20), bgcolor = color.new(color.blue, 85))
    array.push(bullOBBoxes, newBox)
    if array.size(bullOBBoxes) > maxOBBoxes
        box.delete(array.shift(bullOBBoxes))

if showOB and newBearOB and barstate.isconfirmed
    newBox = box.new(bar_index - 1, obHigh, bar_index + obExtendBars, obLow,
         border_color = color.new(color.purple, 20), bgcolor = color.new(color.purple, 85))
    array.push(bearOBBoxes, newBox)
    if array.size(bearOBBoxes) > maxOBBoxes
        box.delete(array.shift(bearOBBoxes))

//====================================================
// PART 3 -- PREMIUM / DISCOUNT ZONES
//====================================================

pdHigh = ta.highest(high, pdLookback)
pdLow  = ta.lowest(low, pdLookback)
pdEq   = (pdHigh + pdLow) / 2

plotHighLine = plot(showPD ? pdHigh : na, "Range High", color = color.new(color.gray, 50))
plotEqLine   = plot(showPD ? pdEq : na, "Equilibrium", color = color.new(color.gray, 30))
plotLowLine  = plot(showPD ? pdLow : na, "Range Low", color = color.new(color.gray, 50))

fill(plotHighLine, plotEqLine, color = showPD ? color.new(color.red, 92) : na, title = "Premium Zone")
fill(plotEqLine, plotLowLine, color = showPD ? color.new(color.green, 92) : na, title = "Discount Zone")

//====================================================
// PART 3 -- EQUAL HIGHS / LOWS + LIQUIDITY HEATMAP
//====================================================

var array<float> pivotHighVals = array.new_float(0)
var array<float> pivotLowVals  = array.new_float(0)

ph = ta.pivothigh(pivotBars, pivotBars)
pl = ta.pivotlow(pivotBars, pivotBars)

if not na(ph)
    array.push(pivotHighVals, ph)
    if array.size(pivotHighVals) > 20
        array.shift(pivotHighVals)

    n = array.size(pivotHighVals)
    if n >= 2
        newestVal = array.get(pivotHighVals, n - 1)
        touchCount = 0
        for j = 0 to n - 2
            if math.abs(newestVal - array.get(pivotHighVals, j)) <= newestVal * eqTolerancePct
                touchCount += 1
        if touchCount >= 1
            if showEQ
                label.new(bar_index[pivotBars], newestVal, "EQH", style = label.style_label_down,
                     color = color.new(color.yellow, 70), textcolor = color.yellow, size = size.tiny)
            if showHeatmap
                heatTrans = math.max(30, 85 - touchCount * 15)
                line.new(bar_index[pivotBars] - 50, newestVal, bar_index[pivotBars], newestVal,
                     color = color.new(color.yellow, heatTrans), width = math.min(touchCount + 1, 4), extend = extend.right)

if not na(pl)
    array.push(pivotLowVals, pl)
    if array.size(pivotLowVals) > 20
        array.shift(pivotLowVals)

    n2 = array.size(pivotLowVals)
    if n2 >= 2
        newestValL = array.get(pivotLowVals, n2 - 1)
        touchCountL = 0
        for j = 0 to n2 - 2
            if math.abs(newestValL - array.get(pivotLowVals, j)) <= newestValL * eqTolerancePct
                touchCountL += 1
        if touchCountL >= 1
            if showEQ
                label.new(bar_index[pivotBars], newestValL, "EQL", style = label.style_label_up,
                     color = color.new(color.orange, 70), textcolor = color.orange, size = size.tiny)
            if showHeatmap
                heatTransL = math.max(30, 85 - touchCountL * 15)
                line.new(bar_index[pivotBars] - 50, newestValL, bar_index[pivotBars], newestValL,
                     color = color.new(color.orange, heatTransL), width = math.min(touchCountL + 1, 4), extend = extend.right)

//====================================================
// PART 3 -- KILLZONES (UTC — matches strategy session bins)
//====================================================

utcHour = hour(time, "UTC")
londonSession  = utcHour >= 7 and utcHour <= 11
nySession      = utcHour >= 12 and utcHour <= 16
overlapSession = utcHour >= 12 and utcHour <= 15
asianSession   = utcHour >= 22 or utcHour <= 6

bgcolor(showKillzones and overlapSession ? color.new(color.purple, 92) :
     showKillzones and nySession ? color.new(color.blue, 93) :
     showKillzones and londonSession ? color.new(color.teal, 93) :
     showKillzones and asianSession ? color.new(color.orange, 94) : na,
     title = "Killzones")

sessionName = overlapSession ? "London/NY Overlap" : nySession ? "New York" : londonSession ? "London" : asianSession ? "Asian" : "Quiet"

//====================================================
// PART 3 -- ENTRY / SL / TP / INVALIDATION LINES
//====================================================

entryTagText = useLimit ? "LIMIT" : "ENTRY"

if showLevels and newLong
    line.new(bar_index, longEntry, bar_index + 30, longEntry, color = limitColor, style = line.style_dashed, width = 2)
    line.new(bar_index, longSL, bar_index + 30, longSL, color = bearColor, style = line.style_dashed)
    line.new(bar_index, longTP, bar_index + 30, longTP, color = bullColor, style = line.style_dashed)
    line.new(bar_index, longInv, bar_index + 30, longInv, color = invColor, style = line.style_dotted)
    label.new(bar_index + 30, longTP, "TP", style = label.style_label_left, color = color.new(bullColor, 80), textcolor = bullColor, size = size.tiny)
    label.new(bar_index + 30, longSL, "SL", style = label.style_label_left, color = color.new(bearColor, 80), textcolor = bearColor, size = size.tiny)
    label.new(bar_index + 30, longEntry, entryTagText + " " + longZone, style = label.style_label_left, color = color.new(color.blue, 80), textcolor = limitColor, size = size.tiny)
    label.new(bar_index + 30, longInv, "INV", style = label.style_label_left, color = color.new(color.orange, 80), textcolor = invColor, size = size.tiny)

if showLevels and newShort
    line.new(bar_index, shortEntry, bar_index + 30, shortEntry, color = limitColor, style = line.style_dashed, width = 2)
    line.new(bar_index, shortSL, bar_index + 30, shortSL, color = bearColor, style = line.style_dashed)
    line.new(bar_index, shortTP, bar_index + 30, shortTP, color = bullColor, style = line.style_dashed)
    line.new(bar_index, shortInv, bar_index + 30, shortInv, color = invColor, style = line.style_dotted)
    label.new(bar_index + 30, shortTP, "TP", style = label.style_label_left, color = color.new(bullColor, 80), textcolor = bullColor, size = size.tiny)
    label.new(bar_index + 30, shortSL, "SL", style = label.style_label_left, color = color.new(bearColor, 80), textcolor = bearColor, size = size.tiny)
    label.new(bar_index + 30, shortEntry, entryTagText + " " + shortZone, style = label.style_label_left, color = color.new(color.blue, 80), textcolor = limitColor, size = size.tiny)
    label.new(bar_index + 30, shortInv, "INV", style = label.style_label_left, color = color.new(color.orange, 80), textcolor = invColor, size = size.tiny)

//====================================================
// PART 3 -- DASHBOARD
//====================================================

var table dash = table.new(position.top_right, 2, 14, border_width = 1, border_color = color.new(color.blue, 50))
dashText = color.new(color.blue, 0)

if barstate.islast and showDashboard
    table.cell(dash, 0, 0, "SMC WHALE AI", text_color = color.white, bgcolor = color.new(color.blue, 30), text_size = size.small)
    table.cell(dash, 1, 0, "", bgcolor = color.new(color.blue, 30))
    table.merge_cells(dash, 0, 0, 1, 0)

    trendLabel = trendBull ? "🟢 BULLISH" : trendBear ? "🔴 BEARISH" : "⚪ NEUTRAL"
    table.cell(dash, 0, 1, "Trend", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 1, trendLabel, text_color = dashText, text_size = size.small)

    regimeLabel = regimeCode == 2 ? "🔶 Volatile" : regimeCode == 1 ? "📈 Trending" : "➖ Ranging"
    table.cell(dash, 0, 2, "Market", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 2, regimeLabel, text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 3, "Confidence", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 3, str.tostring(confidence) + "% / " + str.tostring(confidenceRequired), text_color = dashText, text_size = size.small)

    barBlocks = math.round(confidence / 10)
    barStr = ""
    for i = 1 to 10
        barStr := barStr + (i <= barBlocks ? "█" : "░")
    table.cell(dash, 0, 4, "Conf Bar", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 4, showAIBar ? barStr : "-", text_color = dashText, text_size = size.small)

    edges = (volSpike ? "V" : "-") + (displacementFlag ? "D" : "-") + ((bullSweep or bearSweep) ? "S" : "-") + ((bullFvg or bearFvg) ? "F" : "-") + ((bullCrt or bearCrt) ? "C" : "-")
    table.cell(dash, 0, 5, "Edges", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 5, edges + "  zone=" + activeZone, text_color = dashText, text_size = size.small)

    atrLabel = entryATR > entryATRAvg * 1.3 ? "High" : entryATR < entryATRAvg * 0.7 ? "Low" : "Normal"
    table.cell(dash, 0, 6, "ATR", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 6, atrLabel, text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 7, "RR", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 7, "1 : " + str.tostring(rrValue, "#.##"), text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 8, "Session", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 8, sessionName, text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 9, "SMC Score", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 9, str.tostring(smcScore) + " / 110  (min " + str.tostring(minSetupScore) + " limit)", text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 10, "Mode", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 10, tradeMode + "  " + f_tfLabel(trendTF) + " / " + f_tfLabel(entryTF), text_color = dashText, text_size = size.small)

    table.cell(dash, 0, 11, "Entry", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 11, useLimit ? "📌 Limit (OB/FVG/ATR)" : "⚡ Market (close)", text_color = dashText, text_size = size.small)

    // Live levels for active bias
    liveEntry = trendBull ? longEntry : trendBear ? shortEntry : na
    liveSL    = trendBull ? longSL : trendBear ? shortSL : na
    liveTP    = trendBull ? longTP : trendBear ? shortTP : na
    table.cell(dash, 0, 12, "Levels", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 12,
         na(liveEntry) ? "—" :
         "E " + str.tostring(liveEntry, format.mintick) +
         "  SL " + str.tostring(liveSL, format.mintick) +
         "  TP " + str.tostring(liveTP, format.mintick),
         text_color = dashText, text_size = size.tiny)

    slRoom = (trendBull or trendBear) and not na(liveEntry) and not na(liveSL) and atrSafe > 0 ? math.abs(liveEntry - liveSL) / atrSafe : na
    table.cell(dash, 0, 13, "SL room", text_color = dashText, text_size = size.small)
    table.cell(dash, 1, 13, na(slRoom) ? "—" : str.tostring(slRoom, "#.##") + " ATR (min " + str.tostring(minSlAtr) + ")", text_color = dashText, text_size = size.small)

//====================================================
// PART 3 -- CHART TIMEFRAME GUARD
//====================================================

entrySecs = timeframe.in_seconds(entryTF)

var label tfWarn = na
if barstate.islast
    label.delete(tfWarn)
    if chartSecs > entrySecs
        tfWarn := label.new(bar_index, high,
             "⚠ Chart TF above entry TF (" + f_tfLabel(entryTF) + ")\nSwitch the chart to " + f_tfLabel(entryTF) + " (or lower) for accurate signal markers.\nDashboard is timeframe-independent.",
             style = label.style_label_down, color = color.new(color.orange, 10),
             textcolor = color.white, size = size.small)

//====================================================
// DEBUG PLOTS
//====================================================

plotshape(volSpike, title = "Volume Spike", style = shape.circle, location = location.belowbar, color = color.orange, size = size.tiny)
plotshape(displacementFlag, title = "Displacement", style = shape.triangleup, location = location.belowbar, color = color.aqua, size = size.tiny)
plot(smcScore, "SMC Score", color = color.yellow, display = display.data_window)
plot(confidence, "Confidence", color = color.fuchsia, display = display.data_window)
plot(longEntry, "Long Limit/Entry", color = color.blue, display = display.data_window)
plot(longSL, "Long SL", color = color.red, display = display.data_window)
plot(shortEntry, "Short Limit/Entry", color = color.navy, display = display.data_window)
plot(shortSL, "Short SL", color = color.maroon, display = display.data_window)
